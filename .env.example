# === Supabase ===
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# === World Office (solo prod / live) ===
WO_MODE=mock                 # mock | live
WO_BASE_URL=                 # CONFIRMAR con WO (por-tenant; doc muestra localhost:8080 como placeholder)
WO_CORREO_REGISTRADO=        # para gestionarTokenAPILicencia
WO_TOKEN=                    # JWT (12h) — gestionado por n8n refreshToken en prod

# === n8n ===
# Si N8N_WEBHOOK_CREAR_PEDIDO está presente, la app delega el camino crítico a n8n
# (en vez de sincronizar in-app). N8N_SHARED_SECRET protege los endpoints /api/* que llama n8n.
N8N_WEBHOOK_CREAR_PEDIDO=
N8N_WEBHOOK_AGENTE_BUSQUEDA=
N8N_SHARED_SECRET=

# === Notificaciones (Gmail vía Composio) ===
# Si COMPOSIO_API_KEY está presente, la app envía el correo al confirmar pedido.
# Si no, el envío autónomo lo opera n8n (Fase 2.4). El contenido es el mismo.
COMPOSIO_API_KEY=
COMPOSIO_USER_ID=default
NOTIFICACION_EMAIL=joabon2799@gmail.com   # concurso: Joaquín · prod: contabilidad de E.M.
NEXT_PUBLIC_APP_URL=http://localhost:3000 # base para el link del correo

# === Embeddings (seed) ===
EMBEDDINGS_API_KEY=
